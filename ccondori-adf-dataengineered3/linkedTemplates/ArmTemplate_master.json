{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ccondori-adf-dataengineered3"
		},
		"LS_ADLS_Landing_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://ccondoristad3.dfs.core.windows.net/"
		},
		"LS_AzureSQL_AdventureWorks_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "ccondori-server-central.database.windows.net"
		},
		"LS_AzureSQL_AdventureWorks_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().prm_lnk_dbase}"
		},
		"LS_AzureSQL_AdventureWorks_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "ccondori_admin"
		},
		"lnk_kv_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://ccondori-kv-deed3.vault.azure.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ccondori-adf-dataengineered3_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_Landing_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Landing_properties_typeProperties_url')]"
					},
					"lnk_kv_properties_typeProperties_baseUrl": {
						"value": "[parameters('lnk_kv_properties_typeProperties_baseUrl')]"
					},
					"LS_AzureSQL_AdventureWorks_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_AdventureWorks_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_AdventureWorks_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_AdventureWorks_properties_typeProperties_database')]"
					},
					"LS_AzureSQL_AdventureWorks_properties_typeProperties_userName": {
						"value": "[parameters('LS_AzureSQL_AdventureWorks_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}