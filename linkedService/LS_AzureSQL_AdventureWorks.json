{
	"name": "LS_AzureSQL_AdventureWorks",
	"properties": {
		"parameters": {
			"prm_lnk_dbase": {
				"type": "string",
				"defaultValue": "AdventureWorksLT"
			}
		},
		"annotations": [],
		"type": "AzureSqlDatabase",
		"typeProperties": {
			"server": "ccondori-server-central.database.windows.net",
			"database": "@{linkedService().prm_lnk_dbase}",
			"encrypt": "mandatory",
			"trustServerCertificate": false,
			"authenticationType": "SQL",
			"userName": "ccondori_admin",
			"password": {
				"type": "AzureKeyVaultSecret",
				"store": {
					"referenceName": "lnk_kv",
					"type": "LinkedServiceReference"
				},
				"secretName": "secret-azuresql-adventureworks-password"
			}
		}
	},
	"type": "Microsoft.DataFactory/factories/linkedservices"
}